(kicad_pcb
  (version 20240108)
  (generator "test")
  (generator_version "9.0.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (44 "Edge.Cuts" user)
  )
  (setup
    (pad_to_mask_clearance 0)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
    )
  )
  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC")
  (net 3 "SDA")
  (net 4 "SCL")
  (net 5 "CLK")

  (footprint "Package_DIP:DIP-8_W7.62mm"
    (layer "F.Cu")
    (at 20 30)
    (property "Reference" "U1")
    (property "Value" "IC")
    (pad "1" thru_hole rect
      (at 0 0)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 2 "VCC")
    )
    (pad "2" thru_hole circle
      (at 0 2.54)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 1 "GND")
    )
    (pad "3" thru_hole circle
      (at 0 5.08)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 3 "SDA")
    )
    (pad "4" thru_hole circle
      (at 0 7.62)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 4 "SCL")
    )
    (pad "5" thru_hole circle
      (at 7.62 7.62)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 5 "CLK")
    )
    (pad "6" thru_hole circle
      (at 7.62 5.08)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 1 "GND")
    )
    (pad "7" thru_hole circle
      (at 7.62 2.54)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 2 "VCC")
    )
    (pad "8" thru_hole circle
      (at 7.62 0)
      (size 1.5 1.5)
      (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 1 "GND")
    )
  )

  (footprint "Resistor_SMD:R_0805_2012Metric"
    (layer "F.Cu")
    (at 50 30)
    (property "Reference" "R1")
    (property "Value" "4.7k")
    (pad "1" smd rect
      (at -0.9375 0)
      (size 1.2 1.4)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 3 "SDA")
    )
    (pad "2" smd rect
      (at 0.9375 0)
      (size 1.2 1.4)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "VCC")
    )
  )

  (footprint "Capacitor_SMD:C_0805_2012Metric"
    (layer "F.Cu")
    (at 65 30)
    (property "Reference" "C1")
    (property "Value" "100nF")
    (pad "1" smd rect
      (at -0.9375 0)
      (size 1.2 1.4)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "VCC")
    )
    (pad "2" smd rect
      (at 0.9375 0)
      (size 1.2 1.4)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "GND")
    )
  )

  (gr_rect
    (start 0 0)
    (end 80 60)
    (stroke (width 0.05) (type default))
    (fill none)
    (layer "Edge.Cuts")
  )
)
